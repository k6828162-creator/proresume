<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Resume</title>
  <link rel="stylesheet" href="style.css">

  <!-- AOS Animation -->
  <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
</head>
<body>

<!-- NAVBAR -->
<header>
  <nav>
    <h2>My Portfolio</h2>
    <ul>
      <li><a href="#home">Home</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>
</header>

<!-- HOME -->
<section id="home" data-aos="fade-up">
  <h1>Hi, I'm Mayank 👋</h1>
  <p>Web Developer | Designer</p>
  <a href="resume.pdf" download class="btn">Download Resume</a>
</section>

<!-- ABOUT -->
<section id="about" data-aos="fade-right">
  <h2>About Me</h2>
  <p>I am a passionate web developer creating modern websites.</p>
</section>

<!-- SKILLS -->
<section id="skills" data-aos="fade-left">
  <h2>Skills</h2>
  <div class="skills">
    <span>HTML</span>
    <span>CSS</span>
    <span>JavaScript</span>
  </div>
</section>

<!-- PROJECTS -->
<section id="projects" data-aos="zoom-in">
  <h2>Projects</h2>
  <div class="project">
    <h3>Portfolio Website</h3>
    <p>Modern responsive website</p>
  </div>
</section>

<!-- CONTACT -->
<section id="contact" data-aos="fade-up">
  <h2>Contact Me</h2>

  <form action="https://formspree.io/f/your-id" method="POST">
    <input type="text" name="name" placeholder="Your Name" required>
    <input type="email" name="email" placeholder="Your Email" required>
    <textarea name="message" placeholder="Message" required></textarea>
    <button type="submit">Send</button>
  </form>

</section>

<!-- FOOTER -->
<footer>
  <p>© 2026 Mayank | Resume Website</p>
</footer>

<script src="script.js"></script>
<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script>
  AOS.init();
</script>

</body>
</html>